# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Site
SITE_NAME="Sergio's Corner"
THEME_BACKGROUND=#ffffff       # page background
THEME_FOREGROUND=#111827       # main text — must contrast with background
THEME_MUTED=#6b7280            # secondary text (nav links, footer)
THEME_BORDER=#e5e7eb           # nav and footer separator lines
THEME_PRIMARY=#111827          # site title / brand color

# PostgreSQL
POSTGRES_DB=truqui_center
POSTGRES_USER=truqui
POSTGRES_PASSWORD=truqui
POSTGRES_HOST=db
POSTGRES_PORT=5432
